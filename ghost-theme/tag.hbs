{{!< default}}

<section class="tag-header">
    {{#tag}}
        <h1 class="tag-header__name">{{name}}</h1>
        {{#if description}}
            <p class="tag-header__description">{{description}}</p>
        {{/if}}
    {{/tag}}
</section>

<div class="posts">
    {{#foreach posts}}
        {{> "post-card"}}
    {{/foreach}}
</div>

{{pagination}}
