{{!< default}}

{{#post}}
<article class="{{post_class}} page">
    {{#if @page.show_title_and_feature_image}}
    <header class="page__header">
        {{#if feature_image}}
        <figure class="page__feature-image">
            <img src="{{img_url feature_image size="l"}}"
                 srcset="{{img_url feature_image size="s"}} 400w,
                         {{img_url feature_image size="m"}} 750w,
                         {{img_url feature_image size="l"}} 960w,
                         {{img_url feature_image size="xl"}} 1400w"
                 sizes="(max-width: 760px) 100vw, 720px"
                 alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                 loading="eager">
            {{#if feature_image_caption}}
            <figcaption>{{feature_image_caption}}</figcaption>
            {{/if}}
        </figure>
        {{/if}}
        <h1 class="page__title">{{title}}</h1>
    </header>
    {{/if}}

    <div class="post-content">
        {{content}}
    </div>
</article>
{{/post}}
