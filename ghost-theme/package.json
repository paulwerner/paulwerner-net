{
  "name": "paulwerner",
  "description": "Custom Ghost theme for paulwerner.net",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "email": "tech@paulwerner.net",
    "url": "https://paulwerner.net"
  },
  "keywords": [
    "ghost-theme"
  ],
  "engines": {
    "ghost": ">=5.0.0",
    "ghost-api": "v5"
  },
  "config": {
    "posts_per_page": 10,
    "card_assets": true,
    "image_sizes": {
      "xs": { "width": 150 },
      "s": { "width": 400 },
      "m": { "width": 750 },
      "l": { "width": 960 },
      "xl": { "width": 1400 }
    }
  }
}
