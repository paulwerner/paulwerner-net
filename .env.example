# Template for local/prod Docker Compose environment.
# Copy to .env and fill in real values. Never commit .env.

# ---- MySQL ----
# Root password for the MySQL container (used only by MySQL itself).
MYSQL_ROOT_PASSWORD=change-me
# Database Ghost will connect to.
MYSQL_DATABASE=ghost
# Non-root user Ghost will authenticate as.
MYSQL_USER=ghost
# Password for MYSQL_USER. Keep in sync with GHOST_DATABASE_PASSWORD below.
MYSQL_PASSWORD=change-me

# ---- Ghost database connection ----
# Hostname inside the Docker network — matches the mysql service name.
GHOST_DATABASE_HOST=mysql
# Must match MYSQL_USER.
GHOST_DATABASE_USER=ghost
# Must match MYSQL_PASSWORD.
GHOST_DATABASE_PASSWORD=change-me
# Must match MYSQL_DATABASE.
GHOST_DATABASE_NAME=ghost

# ---- Ghost public URL ----
# The public URL Ghost advertises in feeds, emails, and canonical links.
GHOST_URL=https://blog.paulwerner.net

# ---- Ghost outbound mail (transactional SMTP) ----
# Placeholders — configure when a real mail provider is chosen.
GHOST_MAIL_TRANSPORT=SMTP
GHOST_MAIL_HOST=smtp.example.com
GHOST_MAIL_PORT=587
GHOST_MAIL_USER=change-me
GHOST_MAIL_PASSWORD=change-me

# ---- Ghost staff device verification ----
# 2FA via email on unrecognized devices. Set to false while no SMTP provider
# is configured; re-enable (true) once outbound mail works.
SECURITY_STAFF_DEVICE_VERIFICATION=false

# ---- Caddy / public domains ----
# Root domain — serves the static landing page.
DOMAIN=paulwerner.net
# Blog subdomain — reverse-proxied to the Ghost container.
BLOG_SUBDOMAIN=blog.paulwerner.net
